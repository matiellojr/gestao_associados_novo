# Exemplo de variáveis de ambiente para desenvolvimento
# Copie como `.env` e preencha valores reais. NÃO comite seu `.env`.

# Chave usada para assinar cookies/JWT
GESTAO_SECRET_KEY=

# Banco de dados (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestao_associado_novo
DB_USER=postgres
DB_PASSWORD=

# E-mail / SMTP (opcional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=your@example.com
